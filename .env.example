# 乘务数字化管理平台 - 环境变量配置示例
# 复制此文件为 .env 并按实际部署环境修改
# 当前代码实际读取的主要变量见 config/settings.py、app.py、models/database.py

# ==================== 管理员账户配置 ====================
# 首次初始化数据库时创建的默认管理员账户
APP_USER=admin
APP_PASS=your_secure_password_here

# ==================== 应用配置 ====================
# Flask 密钥（生产环境必须修改为随机值）
# 生成方法: python -c "import os; print(os.urandom(24).hex())"
SECRET_KEY=your_secret_key_here

# 运行环境
# development: 本地开发
# production: 生产部署
FLASK_ENV=production

# 应用运行端口
PORT=5001

# ==================== MySQL 数据库配置 ====================
MYSQL_HOST=127.0.0.1
MYSQL_PORT=3306
MYSQL_USER=root
MYSQL_PASSWORD=your_mysql_password_here
MYSQL_DATABASE=team_management
MYSQL_CHARSET=utf8mb4

# ==================== 会话与上传限制 ====================
# 上传文件大小限制（字节），默认 50MB
MAX_CONTENT_LENGTH=52428800

# Session 过期时间（秒）
SESSION_TIMEOUT=86400

# Cookie 是否仅通过 HTTPS 发送
# 如果当前站点已通过 HTTPS 对外提供服务，建议设为 True
SESSION_COOKIE_SECURE=False

# 是否启用 CSRF 防护
WTF_CSRF_ENABLED=True

# ==================== 其他配置 ====================
# 日志级别 (DEBUG, INFO, WARNING, ERROR, CRITICAL)
LOG_LEVEL=INFO

# ==================== 钉钉免登配置 ====================
# 未启用钉钉免登时可留空
DINGTALK_APP_KEY=your_dingtalk_app_key
DINGTALK_APP_SECRET=your_dingtalk_app_secret
DINGTALK_CORP_ID=your_dingtalk_corp_id
